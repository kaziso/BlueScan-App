<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- ================= TOP: PROJECT INFO (FULL WIDTH) ================= -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="2dp"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="#F8F9FA"
        android:layout_marginBottom="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvProjectInfoName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:text="Project Name"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    
                    <TextView
                        android:id="@+id/tvProjectInfoDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#000000"
                        android:layout_marginEnd="16dp"/>

                    <TextView
                        android:id="@+id/tvProjectInfoRange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#3366cc"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_edit"
                android:textColor="@android:color/white"
                android:backgroundTint="#3366cc"
                android:minHeight="40dp"
                android:layout_marginStart="8dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ================= ROW 2: HEADERS (PARTS LABEL + UNITS SCROLL) ================= -->
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E8F0FE">

        <!-- Fixed "Parts" Header Cell -->
        <TextView
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:minHeight="40dp"
            android:text="Parts"
            android:gravity="center_vertical|start"
            android:paddingStart="16dp"
            android:textStyle="bold"
            android:textColor="#3366cc"
            android:background="#E8F0FE"/>

        <!-- Scrollable Unit Headers -->
        <HorizontalScrollView
            android:id="@+id/hsvHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:importantForAccessibility="no">

            <LinearLayout
                android:id="@+id/llUnitHeaders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"/>

        </HorizontalScrollView>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"/>

    <!-- ================= TABLE BODY ================= -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Part Names (Left Column) -->
            <LinearLayout
                android:id="@+id/llPartNames"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white" />

            <!-- Matrix Cells (Scrollable Right Area) -->
            <HorizontalScrollView
                android:id="@+id/hsvBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:importantForAccessibility="no">

                <LinearLayout
                    android:id="@+id/llMatrixBody"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FAFAFA" />

            </HorizontalScrollView>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
